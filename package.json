{
  "name": "pi-gateway",
  "version": "0.1.0",
  "description": "OpenAI-compatible local API on top of pi.dev — LiteLLM-shape stateless protocol translator. Standalone CLI + pi-extension wrapper.",
  "keywords": [
    "openai",
    "openai-compatible",
    "openai-api",
    "chat-completions",
    "litellm",
    "gateway",
    "llm",
    "proxy",
    "pi",
    "pi-dev",
    "pi-extension",
    "openrouter",
    "openwebui",
    "librechat",
    "claude",
    "gpt",
    "codex",
    "anthropic",
    "ai"
  ],
  "homepage": "https://github.com/bntvllnt/pi-gateway#readme",
  "bugs": {
    "url": "https://github.com/bntvllnt/pi-gateway/issues"
  },
  "license": "MIT",
  "author": "bntvllnt <https://github.com/bntvllnt>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bntvllnt/pi-gateway.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "pi-gateway": "dist/cli.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "src",
    "schemas",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "node ./scripts/build-check.mjs",
    "test": "node ./tests/smoke.mjs && node ./tests/extension-e2e.mjs && node ./tests/contract.mjs",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@mariozechner/jiti": "^2.6.5",
    "@types/node": "^24.12.2",
    "@vllnt/eslint-config": "^1.0.1",
    "@vllnt/typescript": "^1.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check"
  }
}
